        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@repo/types": "*",
        "pg": "^8.13.3"
    },
    "devDependencies": {
        "@repo/config": "*",
        "@types/pg": "^8.11.11",
        "dotenv": "^16.4.7",
        "drizzle-kit": "^0.20.18",
        "drizzle-orm": "^0.30.10",
        "typescript": "^5.7.3"
    }
