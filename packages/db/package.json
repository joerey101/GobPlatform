{
    "name": "@repo/db",
    "version": "0.0.1",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./schema": "./src/schema/index.ts",
        "./src/queries/*": "./src/queries/*.ts"
    },
    "scripts": {
        "db:generate": "drizzle-kit generate",
